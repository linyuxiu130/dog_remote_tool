#!/usr/bin/env bash
set -euo pipefail

SELF="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$SELF")"
fi
TOOL_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(cd "$TOOL_DIR/.." && pwd)"
export LD_LIBRARY_PATH="$ROOT_DIR/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

exec "$TOOL_DIR/dfu-util.real" "$@"
